{
  "name": "Asuma Bot - Smart WhatsApp Automation",
  "short_name": "Asuma Bot",
  "description": "Asuma adalah bot WhatsApp multifungsi — AI assistant, manajemen grup, downloader media, RPG & games, dan lebih dari 100 perintah siap pakai.",
  "start_url": "/",
  "scope": "/",
  "id": "/?source=pwa",
  "display": "standalone",
  "display_override": [
    "standalone",
    "minimal-ui",
    "fullscreen",
    "browser",
    "window-controls-overlay"
  ],
  "background_color": "#09090b",
  "theme_color": "#0f172a",
  "orientation": "any",
  "lang": "id",
  "dir": "ltr",
  "categories": [
    "utilities",
    "productivity",
    "communication",
    "social"
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": [
            "image/*",
            "video/*",
            "audio/*",
            "application/pdf",
            ".pdf"
          ]
        }
      ]
    }
  },
  "screenshots": [
    {
      "src": "/screenshots/mobile.png",
      "sizes": "1080x2340",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Tampilan Home Asuma Bot"
    },
    {
      "src": "/screenshots/desktop.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Tampilan Dashboard Asuma Bot"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "file_handlers": [
    {
      "action": "/process-file",
      "accept": {
        "image/*": [".jpg", ".jpeg", ".png"],
        "text/plain": [".txt"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+asuma",
      "url": "/?command=%s"
    }
  ],
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.asuma.bot",
      "id": "com.asuma.bot"
    }
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "widgets": [
    {
      "name": "Asuma Bot Status",
      "description": "Cek status bot langsung dari layar utama",
      "tag": "asuma-status",
      "ms_ac_template": "/widgets/template.json",
      "data": "/widgets/data.json",
      "type": "application/json"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "note_taking": {
    "new_note_url": "/new-note"
  },
  "scope_extensions": [
    {
      "origin": "https://*.asuma.my.id"
    }
  ],
  "icons": [
