    "standalone",
    "minimal-ui",
    "fullscreen",
    "browser",
    "window-controls-overlay"
  ],
  "background_color": "#09090b",
  "theme_color": "#0f172a",
  "orientation": "any",
  "lang": "id",
  "dir": "ltr",
